# aliases
alias ls="lsd -la --color=auto --group-directories-first"
#alias ls="exa -lra --color=auto --icons --group-directories-first"
alias history="history 1"
alias hg="history | grep"

alias gb='git branch --show-current'
alias gs='git status'
alias ga='git add'
alias gc='git commit'
alias gd='git diff'
alias gp='git push origin $(gb)'
alias gpull='git pull origin $(gb)'
alias gco='git checkout'
alias gcob='git checkout -b'
alias gpr='git pull origin release --rebase'

alias gwta='git worktree add'
alias gwtl='git worktree list'
alias gwtm='git worktree move'
alias gwtr='git worktree remove'

# Create worktree, cd into it, and copy .env.local from parent
gwt() {
  gwta "$1" -b "$2" && cd "$1" && cp ../.env.local .
}


alias zshsrc='source ~/.zshrc'
alias zshconfig="nvim ~/.zshrc"
alias nvimconfig="nvim ~/.config/nvim/init.lua"
alias tmuxconfig="nvim ~/.config/tmux/tmux.conf"


alias cdcp="cd ~/git/ClientPortal/"
